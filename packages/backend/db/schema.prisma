generator client {
  provider      = "prisma-client-js"
  // ¡CLAVE PARA DOCKER! Asegura que el cliente funcione tanto en tu PC local como en el contenedor Linux
  binaryTargets = ["native", "linux-musl", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

// Enum para saber en qué estado está la adquisición
enum MergerStatus {
  ANNOUNCED // Recién anunciada, sujeta a revisión
  PENDING   // En proceso (Este es el estado que nos interesa para el MVP)
  COMPLETED // Fusión cerrada (Ya no hay arbitraje)
  CANCELLED // Fusión bloqueada o cancelada (El spread colapsa)
}

// Enum para el tipo de adquisición
enum AcquisitionType {
  CASH
  STOCK
  MIXED
}

// El modelo principal (Nuestra "Capa Estática")
model Merger {
  id                  String       @id @default(uuid())
  
  // Empresa Objetivo (La que va a ser comprada)
  targetTicker        String       @unique // Ej: "CPRI"
  targetName          String       // Ej: "Capri Holdings"
  
  // Empresa Compradora
  buyerName           String       // Ej: "Tapestry"
  buyerTicker         String?      // Opcional, por si queremos mostrarla, aunque no la usemos para el cálculo
  
  // Datos de la Oferta
  acquisitionType     AcquisitionType @default(CASH)
  offerPrice          Float        // Ej: 57.00. (Usamos Float por simplicidad en la Hackathon)
  cashAmount          Float?       // Para MIXED o CASH (si queremos ser redundantes)
  exchangeRatio       Float?       // Para STOCK o MIXED
  currency            String       @default("USD")
  
  // Metadatos de la operación
  status              MergerStatus @default(PENDING)
  announcedDate       DateTime     // Cuándo se hizo pública la noticia
  expectedClosingDate DateTime?    // Ej: "Q4 2026" (Suele ser ambiguo en la vida real, por eso String)
  
  // Timestamps for price updates
  lastTargetPriceUpdate DateTime?
  lastBuyerPriceUpdate  DateTime?

  // Timestamps automáticos
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  @@index([status]) // Índice para que la búsqueda de fusiones "PENDING" sea ultra rápida
}