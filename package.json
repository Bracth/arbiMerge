{
  "name": "arbimerge-monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "backend": "npm run --workspace=@arbimerge/backend",
    "frontend": "npm run --workspace=@arbimerge/frontend",
    "shared": "npm run --workspace=@arbimerge/shared",
    "db:seed": "npm run --workspace=@arbimerge/backend db:seed",
    "frontend:dev": "npm run --workspace=@arbimerge/frontend dev"
  }
}
